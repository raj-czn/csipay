<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorWhite"
    android:baselineAligned="false"
    android:clipToPadding="false"
    tools:context="com.verifone.payment_sdk.ui.navigator.NavigatorActivity">
    <LinearLayout
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:baselineAligned="false">
        <LinearLayout
            android:id="@+id/on_hide_one_layout"
            android:layout_width="0dp"
            android:layout_weight="0.05"
            android:orientation="vertical"
            android:visibility="visible"
            android:layout_height="match_parent"/>
        <RelativeLayout
            android:id="@+id/main_content_layout"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:background="@color/colorWhite">
            <LinearLayout
                android:id="@+id/main_fragment_root_layout"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
        </RelativeLayout>
        <LinearLayout
            android:id="@+id/on_hide_two_layout"
            android:layout_width="0dp"
            android:layout_weight="0.05"
            android:orientation="vertical"
            android:gravity="end"
            android:visibility="visible"
            android:layout_height="match_parent"/>
        <LinearLayout
            android:id="@+id/on_show_info_layout"
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:visibility="gone"
            android:elevation="@dimen/help_layout_shadow"
            android:layout_height="match_parent"
            android:background="@color/background_color"
            android:outlineProvider="bounds"
            android:paddingStart="@dimen/help_heading_margin_bottom"
            android:paddingEnd="@dimen/help_heading_margin_bottom">
            <include
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                layout="@layout/navigator_help_layout" />
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:id="@+id/main_help_menu_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <View
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"/>
        <ImageView
            android:id="@+id/main_help_menu_button"
            android:layout_width="0dp"
            android:layout_weight=".25"
            android:layout_height="wrap_content"
            android:layout_gravity="end|top"
            android:src="@drawable/help_icon"
            android:contentDescription="@string/navigator_menu_button_description"/>
    </LinearLayout>

</RelativeLayout>
