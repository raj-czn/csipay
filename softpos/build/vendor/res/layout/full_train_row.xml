<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/full_train_row_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="@dimen/divider_margin"
    android:background="@drawable/layout_background_selector"
    android:baselineAligned="false">
    <TextView
        android:id="@+id/full_train_row_text"
        style="@style/train_button_text_style"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layout_toStartOf="@id/full_train_row_start_button"
        />
    <TextView
        android:id="@+id/full_train_row_start_button"
        style="@style/train_button_style"
        android:layout_alignParentEnd="true"
        />
</RelativeLayout>
