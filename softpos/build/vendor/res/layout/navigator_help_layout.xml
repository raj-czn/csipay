<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:id="@+id/close_window_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:orientation="horizontal">
        <View
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"/>
        <ImageView
            android:id="@+id/main_help_cancel_button"
            android:layout_width="0dp"
            android:layout_weight=".25"
            android:layout_height="wrap_content"
            android:layout_gravity="end|top"
            android:src="@drawable/close_window"
            android:contentDescription="@string/close_help_window"/>
    </LinearLayout>
   <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
       android:layout_marginTop="@dimen/help_heading_margin_top">
       <LinearLayout
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:orientation="vertical"
           android:padding="@dimen/main_tile_layout_side_margin">
           <TextView
               android:id="@+id/help_main_heading_text"
               style="@style/help_heading_text"
               android:text="@string/help_guidelines"/>
           <TextView
               android:visibility="visible"
               android:id="@+id/help_main_disabled_desc_text"
               style="@style/help_desc_text"
               android:text="@string/accessibility_and_assistance_mode_will_be_disabled"/>
           <LinearLayout
               android:id="@+id/help_main_layout"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:orientation="vertical"
               android:visibility="gone">
               <TextView
                   android:id="@+id/help_main_subheading_text1"
                   style="@style/help_subheading_text"
                   android:text="@string/difficulty_seeing_screen"/>
               <TextView
                   android:id="@+id/help_main_descheading_text1"
                   style="@style/help_descheading_text"
                   android:text="@string/would_you_like_high_contrast"/>
               <TextView
                   android:id="@+id/help_main_desc_text1"
                   style="@style/help_desc_text"
                   android:text="@string/tap_assistance_button"/>
               <TextView
                   android:id="@+id/help_main_subheading_text2"
                   style="@style/help_subheading_text"
                   android:text="@string/blind"/>
           </LinearLayout>
           <LinearLayout
               android:id="@+id/help_accessibility_layout"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:orientation="vertical"
               android:visibility="gone">
               <TextView
                   android:id="@+id/help_main_descheading_text2"
                   style="@style/help_descheading_text"
                   android:text="@string/have_you_used_touch_screen_terminal"/>
               <TextView
                   android:id="@+id/help_main_desc_text2"
                   style="@style/help_desc_text"
                   android:text="@string/yes_you_can_double_tap"/>
               <TextView
                   android:id="@+id/help_main_desc_text3"
                   style="@style/help_desc_text"
                   android:text="@string/no_would_you_like_training"/>
               <TextView
                   android:id="@+id/help_main_desc_text4"
                   style="@style/help_desc_text"
                   android:text="@string/tap_training_button"/>
           </LinearLayout>
           <LinearLayout
               android:id="@+id/help_assistance_layout"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:orientation="vertical"
               android:visibility="gone">
               <TextView
                   android:id="@+id/help_assist_descheading_text"
                   style="@style/help_descheading_text"
                   android:text="@string/shall_we_try_speech_options"/>
               <TextView
                   android:id="@+id/help_assist_text"
                   style="@style/help_desc_text"
                   android:text="@string/tap_amount_vocalization_button"/>
           </LinearLayout>
           <LinearLayout
               android:id="@+id/help_train_layout"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:orientation="vertical"
               android:visibility="gone">
               <TextView
                   android:id="@+id/help_train_subheading_text"
                   style="@style/help_subheading_text"
                   android:text="@string/struggles_to_hear"/>
               <TextView
                   android:id="@+id/help_train_desc_text"
                   style="@style/help_desc_text"
                   android:text="@string/are_you_having_difficulty_hearing_the_device"/>
           </LinearLayout>
       </LinearLayout>
    </ScrollView>
</RelativeLayout>