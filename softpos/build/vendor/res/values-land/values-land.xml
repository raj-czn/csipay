<?xml version="1.0" encoding="utf-8"?>
<resources>
    <dimen name="description_text">16sp</dimen>
    <dimen name="divider_margin">5dp</dimen>
    <dimen name="heading_text">24sp</dimen>
    <dimen name="help_button_height">28dp</dimen>
    <dimen name="help_heading_margin_bottom">14dp</dimen>
    <dimen name="help_heading_margin_top">50dp</dimen>
    <dimen name="help_heading_text">16sp</dimen>
    <dimen name="help_icon_portrait_margin">15dp</dimen>
    <dimen name="help_layout_shadow">6dp</dimen>
    <dimen name="help_text">14sp</dimen>
    <dimen name="help_text_margin">12dp</dimen>
    <dimen name="help_text_padding">5dp</dimen>
    <dimen name="logo_image_margin">30dp</dimen>
    <dimen name="logo_image_margin_bottom">30dp</dimen>
    <dimen name="main_layout_margin">10dp</dimen>
    <dimen name="main_layout_side_margin">12dp</dimen>
    <dimen name="main_tile_layout_side_margin">20dp</dimen>
    <dimen name="switch_button_width">60dp</dimen>
    <dimen name="toggle_button_margin">10dp</dimen>
    <dimen name="toggle_button_text">18sp</dimen>
    <dimen name="toggle_button_width">80dp</dimen>
    <dimen name="train_button_text">20sp</dimen>
    <dimen name="train_button_width">100dp</dimen>
    <dimen name="train_desc_text">18sp</dimen>
    <dimen name="train_exit_button_text">24sp</dimen>
    <dimen name="train_heading_text">40sp</dimen>
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>
    <style name="fragment_description_text_style">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textSize">@dimen/description_text</item>
        <item name="android:textColor">@color/text_gray</item>
    </style>
    <style name="fragment_divider_style">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:alpha">0.3</item>
        <item name="android:background">@color/text_gray</item>
        <item name="android:layout_marginTop">@dimen/divider_margin</item>
        <item name="android:layout_marginBottom">@dimen/divider_margin</item>
    </style>
    <style name="fragment_heading_text_style">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/heading_text</item>
        <item name="android:textColor">@color/text_gray</item>
    </style>
    <style name="fragment_layout_style">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:paddingBottom">@dimen/main_layout_margin</item>
    </style>
    <style name="fragment_switch_style">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:switchMinWidth">@dimen/switch_button_width</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_alignParentEnd">true</item>
        <item name="android:layout_centerInParent">true</item>
    </style>
    <style name="fragment_tile_layout_style">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingTop">@dimen/main_layout_side_margin</item>
        <item name="android:paddingBottom">@dimen/main_layout_side_margin</item>
    </style>
    <style name="fragment_train_desc_style">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">start</item>
        <item name="android:textSize">@dimen/train_desc_text</item>
        <item name="android:color">@color/text_gray</item>
    </style>
    <style name="fragment_train_double_tap_text_style">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">start</item>
        <item name="android:textSize">@dimen/train_desc_text</item>
        <item name="android:textColor">@color/text_green</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginTop">@dimen/divider_margin</item>
    </style>
    <style name="fragment_train_title_style">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">start</item>
        <item name="android:textSize">@dimen/train_heading_text</item>
        <item name="android:textStyle">bold</item>
        <item name="android:color">@color/text_gray</item>
    </style>
    <style name="help_desc_text">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">start</item>
        <item name="android:layout_marginBottom">@dimen/main_tile_layout_side_margin</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/train_desc_text</item>
        <item name="android:textColor">@color/text_gray</item>
        <item name="android:textStyle">normal</item>
    </style>
    <style name="help_descheading_text">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">start</item>
        <item name="android:layout_marginBottom">@dimen/main_layout_margin</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/train_desc_text</item>
        <item name="android:textColor">@color/text_gray</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="help_heading_text">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">start</item>
        <item name="android:layout_marginBottom">@dimen/main_tile_layout_side_margin</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/heading_text</item>
        <item name="android:textColor">@color/text_gray</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="help_subheading_text">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">start</item>
        <item name="android:layout_marginBottom">@dimen/main_layout_margin</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/train_desc_text</item>
        <item name="android:textColor">@color/colorBlue</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="main_help_button_style">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">end</item>
        <item name="android:src">@drawable/help_icon</item>
        <item name="android:layout_marginTop">@dimen/main_layout_margin</item>
    </style>
    <style name="main_logo_style">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:src">@drawable/verifone_navigator_logo</item>
        <item name="android:layout_marginTop">@dimen/logo_image_margin</item>
        <item name="android:layout_marginLeft">@dimen/main_tile_layout_side_margin</item>
        <item name="android:layout_marginRight">@dimen/main_tile_layout_side_margin</item>
    </style>
    <style name="toggle_button_style">
        <item name="android:layout_width">@dimen/toggle_button_width</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">@dimen/toggle_button_margin</item>
        <item name="android:layout_marginLeft">@dimen/toggle_button_margin</item>
        <item name="android:layout_marginTop">@dimen/divider_margin</item>
        <item name="android:layout_marginBottom">@dimen/divider_margin</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/train_button_text</item>
        <item name="android:textColor">@color/toggle_text_blue</item>
        <item name="android:background">@drawable/button_background_selector</item>
    </style>
    <style name="train_button_style">
        <item name="android:layout_width">@dimen/train_button_width</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingTop">@dimen/toggle_button_margin</item>
        <item name="android:paddingBottom">@dimen/toggle_button_margin</item>
        <item name="android:layout_marginLeft">@dimen/toggle_button_margin</item>
        <item name="android:layout_marginTop">@dimen/divider_margin</item>
        <item name="android:layout_marginBottom">@dimen/divider_margin</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/train_button_text</item>
        <item name="android:textColor">@color/toggle_text_blue</item>
        <item name="android:background">@drawable/button_background_selector</item>
    </style>
    <style name="train_button_text_style">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">start</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/train_desc_text</item>
        <item name="android:textColor">@color/text_gray</item>
    </style>
    <style name="train_exit_button_style">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/exit_button_background</item>
        <item name="android:gravity">center</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/train_exit_button_text</item>
        <item name="android:textColor">@color/colorWhite</item>
        <item name="android:layout_marginBottom">@dimen/main_layout_margin</item>
    </style>
</resources>