<PreferenceScreen xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <PreferenceCategory android:title="Debug">

        <ListPreference
            android:defaultValue="@string/default_scanner"
            android:entries="@array/scanners"
            android:entryValues="@array/scanners"
            android:key="prefs_scanner"
            android:title="Scanner" />

        <SwitchPreference
            android:defaultValue="false"
            android:key="prefs_kpi_mode"
            android:title="Kpi mode" />

        <ListPreference
            android:defaultValue="2"
            android:entries="@array/confidence_count"
            android:entryValues="@array/confidence_count"
            android:key="prefs_confidence_count"
            android:title="Confidence count" />

        <ListPreference
            android:defaultValue="90"
            android:entries="@array/scanning_orientations"
            android:entryValues="@array/scanning_orientations"
            android:key="prefs_scanning_orientations"
            android:title="Scanning orientations(deg)" />

        <EditTextPreference
            android:defaultValue="1000"
            android:key="prefs_debounce_duration"
            android:selectAllOnFocus="true"
            android:singleLine="true"
            android:title="Debounce duration(ms)" />

    </PreferenceCategory>

    <PreferenceCategory android:title="Focus">

        <ListPreference
            android:defaultValue="@string/focus_mode_continuous"
            android:key="prefs_focus_mode"
            android:title="Focus mode"
            android:entries="@array/focus_modes"
            android:entryValues="@array/focus_modes"/>

        <EditTextPreference
            android:defaultValue="8"
            android:key="prefs_diopter_pos"
            android:selectAllOnFocus="true"
            android:singleLine="true"
            android:title="Manual focus diopter position" />

    </PreferenceCategory>

    <PreferenceCategory android:title="Product Codes">

        <CheckBoxPreference
            android:defaultValue="true"
            android:key="prefs_upc_a"
            android:title="UPC_A" />
        <CheckBoxPreference
            android:defaultValue="true"
            android:key="prefs_upc_e"
            android:title="UPC_E" />
        <CheckBoxPreference
            android:defaultValue="true"
            android:key="prefs_ean_13"
            android:title="EAN_13" />
        <CheckBoxPreference
            android:defaultValue="true"
            android:key="prefs_ean_8"
            android:title="EAN_8" />
        <CheckBoxPreference
            android:defaultValue="true"
            android:key="prefs_rss_14"
            android:title="RSS_14" />
        <CheckBoxPreference
            android:defaultValue="true"
            android:key="prefs_rss_expanded"
            android:title="RSS_EXPANDED" />

    </PreferenceCategory>

    <PreferenceCategory android:title="Industrial Codes">

        <CheckBoxPreference
            android:defaultValue="true"
            android:key="prefs_code_39"
            android:title="CODE_39" />
        <CheckBoxPreference
            android:defaultValue="true"
            android:key="prefs_code_93"
            android:title="CODE_93" />
        <CheckBoxPreference
            android:defaultValue="true"
            android:key="prefs_code_128"
            android:title="CODE_128" />
        <CheckBoxPreference
            android:defaultValue="true"
            android:key="prefs_itf"
            android:title="ITF" />
        <CheckBoxPreference
            android:defaultValue="true"
            android:key="prefs_codabar"
            android:title="CODABAR" />
        <CheckBoxPreference
            android:defaultValue="true"
            android:key="prefs_gs1_128"
            android:title="GS1_128" />

    </PreferenceCategory>

    <PreferenceCategory android:title="2D Codes">

        <CheckBoxPreference
            android:defaultValue="false"
            android:key="prefs_qr_code"
            android:title="QR_CODE" />
        <CheckBoxPreference
            android:defaultValue="false"
            android:key="prefs_datamatrix"
            android:title="DATAMATRIX" />
        <CheckBoxPreference
            android:defaultValue="false"
            android:key="prefs_aztec"
            android:title="AZTEC" />
        <CheckBoxPreference
            android:defaultValue="false"
            android:key="prefs_pdf417"
            android:title="PDF417" />

    </PreferenceCategory>


</PreferenceScreen>

